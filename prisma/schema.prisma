// Prisma schema — Postgres (Supabase).
// The app runs fine without a database; these models are used only
// when DATABASE_URL is set (roast history + NextAuth session storage).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── App data ────────────────────────────────────────────────
model Roast {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  fileName     String   @default("resume.pdf")
  overallScore Int
  verdict      String
  data         Json // full roast result (categories, strengths, improvements, …)
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
}

// ── NextAuth models ─────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  roasts        Roast[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
