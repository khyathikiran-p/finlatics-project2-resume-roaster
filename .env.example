# ─────────────────────────────────────────────────────────────
# REQUIRED — the app roasts resumes with Claude
# Get a key at https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────
# OPTIONAL — persistence (Prisma + Supabase Postgres)
# If unset, the app still works; roasts just aren't saved to a DB.
# Supabase → Project Settings → Database → Connection string (URI)
# ─────────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require"

# ─────────────────────────────────────────────────────────────
# OPTIONAL — sign-in with Google (NextAuth)
# If unset, the app runs in guest mode (no login required).
# ─────────────────────────────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=run: openssl rand -base64 32
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Set to "true" to show the Sign-in button in the header
# NEXT_PUBLIC_AUTH_ENABLED=false
