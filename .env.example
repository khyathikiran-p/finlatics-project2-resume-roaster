# ─────────────────────────────────────────────────────────────
# REQUIRED — the app roasts resumes with Claude
# Get a key at https://console.anthropic.com/settings/keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────
# OPTIONAL — persistence (Prisma + Supabase Postgres)
# When set, each roast is saved to the `roasts` table
# (id, user_id, resume_text, roast_json, created_at).
# Supabase → Project Settings → Database → Connection string (URI)
# ─────────────────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require"

# ─────────────────────────────────────────────────────────────
# OPTIONAL — sign-in (NextAuth). When at least one provider is set,
# /api/roast requires a signed-in session (getServerSession).
# With none set, the app runs in guest mode (rate-limited by IP).
# ─────────────────────────────────────────────────────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=run: openssl rand -base64 32

# GitHub OAuth → https://github.com/settings/developers (New OAuth App)
#   Callback URL: <NEXTAUTH_URL>/api/auth/callback/github
# GITHUB_ID=
# GITHUB_SECRET=

# Google OAuth → https://console.cloud.google.com/apis/credentials
#   Callback URL: <NEXTAUTH_URL>/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Set to "true" to show the Sign-in button in the header
# NEXT_PUBLIC_AUTH_ENABLED=false

# ─────────────────────────────────────────────────────────────
# Rate limiting is built in (in-memory counter, per user/IP).
# For multi-instance production, back it with Upstash Redis instead.
# ─────────────────────────────────────────────────────────────
